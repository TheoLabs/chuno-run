{
  "name": "@chuno/mobile",
  "version": "0.0.1",
  "private": true,
  "description": "Flutter 앱을 turbo 파이프라인에 연동하기 위한 래퍼. 실제 빌드/실행은 flutter CLI가 수행한다.",
  "scripts": {
    "gen": "flutter create --org run.chuno --project-name mobile --platforms=android,ios .",
    "dev": "bash tools/watch_run.sh",
    "run": "flutter run",
    "build": "flutter build apk --debug",
    "lint": "flutter analyze",
    "typecheck": "flutter analyze",
    "test": "flutter test"
  }
}
