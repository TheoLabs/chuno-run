# MYSQL
MYSQL_HOST = localhost
MYSQL_USERNAME = root
MYSQL_PASSWORD = 1234
MYSQL_DATABASE = chuno_run

# JWT
ACCESS_TOKEN_EXPIRED = 1d
ACCESS_TOKEN_SECRET = 1

# ADMIN (로컬 시드: pnpm seed:admin 이 이 이메일로 초기 ACTIVE 관리자 1명을 생성)
INITIAL_ADMIN_EMAIL = admin@chuno.run

# Kafka (docker-compose.yml 의 kafka 서비스 기준 / 미설정 시 아래 값이 기본값)
KAFKA_CLIENT_ID=core-api
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=core-api
KAFKA_DDD_EVENT_TOPIC=chuno.chuno_run.ddd_event

# REDIS
REDIS_HOST=localhost
REDIS_PORT=6379

# GOOGLE OAUTH (관리자 로그인 ID token 검증용 클라이언트 ID / 공개값)
GOOGLE_CLIENT_ID=1028748335532-6vhno6257qs6n7b2uv2f64prqqs073bf.apps.googleusercontent.com

# SCHEDULER
SCHEDULER_JOB_TOKEN=9efdoiphejkl3jkl$@q309-1sl

# APP SOCIAL LOGIN (앱 소셜 로그인 서버 검증용 공개값)
# 구글 ID 토큰 audience — iOS/Android 클라이언트 ID 를 쉼표로 나열한다.
GOOGLE_APP_CLIENT_IDS=
# 애플 identity token audience — 앱 번들 ID / 서비스 ID 를 쉼표로 나열한다.
APPLE_CLIENT_IDS=
# 카카오는 액세스 토큰을 카카오 API 로 직접 확인하므로 서버 측 키가 필요 없다.

# FCM PUSH (2차 — 서비스 계정 JSON을 base64로. 미설정 시 푸시는 로그만 남김)
FIREBASE_SERVICE_ACCOUNT=
# 서버 정합성 재검증 임계값 (2차 — 실측 로그로 튜닝)
REVALIDATION_MAX_SPEED_MPS=6.5
REVALIDATION_MIN_PACE_SEC_PER_KM=120
REVALIDATION_MAX_TIMESTAMP_SKEW_SEC=30
