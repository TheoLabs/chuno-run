# MYSQL
MYSQL_HOST = localhost
MYSQL_USERNAME = root
MYSQL_PASSWORD = 1234
MYSQL_DATABASE = chuno_run

# JWT
ACCESS_TOKEN_EXPIRED = 1d
ACCESS_TOKEN_SECRET = 1

# ADMIN (로컬 시드: pnpm seed:admin 이 이 이메일로 초기 ACTIVE 관리자 1명을 생성)
INITIAL_ADMIN_EMAIL = admin@chuno.run

# Kafka (docker-compose.yml 의 kafka 서비스 기준 / 미설정 시 아래 값이 기본값)
KAFKA_CLIENT_ID=core-api
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=core-api
KAFKA_DDD_EVENT_TOPIC=chuno.chuno_run.ddd_event

# REDIS
REDIS_HOST=localhost
REDIS_PORT=6379
