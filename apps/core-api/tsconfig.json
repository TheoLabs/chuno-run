{
  "extends": "@chuno/tsconfig/nestjs.json",
  "compilerOptions": {
    "outDir": "./dist",
    "baseUrl": "./",
    "strictPropertyInitialization": false,
    "paths": {
      "@modules/*": ["src/modules/*"],
      "@middlewares": ["src/middlewares"],
      "@libs/*": ["src/libs/*"],
      "@databases": ["src/databases"],
      "@configs": ["src/configs"],
      "@types": ["src/types"],
      "@guards": ["src/guards"]
    }
  },
  "include": ["src/**/*", "test/**/*"],
  "exclude": ["node_modules", "dist"],
  "ts-node": {
    "require": ["tsconfig-paths/register"],
    "compilerOptions": {
      "module": "commonjs"
    }
  }
}
